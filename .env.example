# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=audit_intelligence

# Retrieval
USE_FAISS=false
TOP_K=5
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Review / confidence
CONFIDENCE_THRESHOLD=0.65
MAX_RETRY=1

# Optional local models (all must exist on disk to stay offline)
LOCAL_LLM_PATH=models/tinyllama
LOCAL_EMBEDDING_MODEL_PATH=models/embeddings
BASE_FINETUNE_MODEL_PATH=models/tinyllama

# Training
FINETUNE_OUTPUT_DIR=outputs/models
FINETUNE_MAX_LENGTH=384
FINETUNE_EPOCHS=1
FINETUNE_BATCH_SIZE=2
FINETUNE_LEARNING_RATE=0.0002

# Misc
REPORT_AUTHOR=Audit Intelligence System
ENABLE_LLM_LABEL_REFINEMENT=true
